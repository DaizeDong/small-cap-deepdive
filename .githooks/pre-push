#!/bin/sh
# PER-REPO pre-push -- the strict local backstop: tree + EVERY commit reachable from any ref
# (blobs, messages, author/committer identity).
#
# Full history is the right scope HERE and only here: this is a repo we own and have already cleaned,
# so it stays green, and a regression anywhere in it is a real finding. The machine-wide hook cannot
# do this -- it also runs in forks, whose upstream history holds thousands of other people's
# mailboxes -- so it checks the push range instead.
#
# This is the boundary the 2026-07 leaks crossed. Each was "fixed" by editing the file, so the tree
# was clean at push time and the commit that introduced the PII went to GitHub anyway. A guard that
# only looked at the tree would have waved every single one of them through.
#
# It is also where an agent fools itself: `pytest -q && git push` reports the PUSH's exit code, so a
# failing test still ships. A hook cannot be masked that way.
#
# Output is captured, not piped -- see the note in pre-commit. A verdict a caller's `| head` can
# destroy is not a verdict. Belt and braces: the same scan runs in CI (.github/workflows/
# pii-guard.yml), which no local shell quirk and no --no-verify can reach.
ROOT="$(git rev-parse --show-toplevel)"
GUARD="$ROOT/tools/pii_guard.py"
BOUNDARY="$ROOT/tools/data_boundary.py"
[ -f "$GUARD" ] || exit 0
PY=$(command -v python || command -v python3 || command -v py) || exit 0

out=$("$PY" "$GUARD" --tree --history 2>&1)
rc=$?
if [ "$rc" -ne 0 ]; then
  printf '%s\n' "$out"
  echo ""
  echo "push BLOCKED by pii_guard: real private data would become public and permanent."
  echo "A file edit is NOT a fix once it is in a commit -- rewrite the history (git filter-repo)."
  exit 1
fi

# The DATA BOUNDARY (see the note in pre-commit). Checked again at the push boundary, because this
# is the last moment anything is still private -- and because a commit can arrive here without ever
# passing pre-commit (a merge, a cherry-pick, a rebase, another clone, --no-verify).
[ -f "$BOUNDARY" ] || exit 0
out=$("$PY" "$BOUNDARY" 2>&1)
rc=$?
[ "$rc" -eq 0 ] && exit 0

printf '%s\n' "$out"
echo ""
echo "push BLOCKED by data_boundary: this repo is not an uninitialized tool."
echo "Real-run output would become public and permanent. Move it to the private store."
exit 1
